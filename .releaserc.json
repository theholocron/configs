{
  "branches": ["main", { "name": "alpha", "prerelease": true }],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "chore", "scope": "deps", "release": "patch" },
          { "breaking": true, "release": "major" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "Features" },
            { "type": "fix", "section": "Bug Fixes" },
            { "type": "perf", "section": "Performance" },
            { "type": "refactor", "section": "Refactoring" },
            { "type": "docs", "section": "Documentation", "hidden": false },
            { "type": "chore", "section": "Chores", "hidden": false },
            { "type": "ci", "section": "CI", "hidden": true },
            { "type": "test", "section": "Tests", "hidden": true }
          ]
        }
      }
    ],
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "pnpm exec holocron npm bump-versions ${nextRelease.version}",
        "publishCmd": "for dir in packages/*/; do pkg=$(node -p \"require('./$dir/package.json').name\"); ver=$(node -p \"require('./$dir/package.json').version\"); private=$(node -p \"require('./$dir/package.json').private || false\"); [ \"$private\" = \"true\" ] && continue; npm view \"${pkg}@${ver}\" version 2>/dev/null && echo \"skip ${pkg}@${ver} (already published)\" || pnpm --filter \"./$dir\" publish --access public --no-git-checks --tag ${nextRelease.channel || 'latest'}; done"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json", "packages/*/package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}\n\nSigned-off-by: Newton <5769156+iamnewton@users.noreply.github.com>"
      }
    ],
    "@semantic-release/github"
  ]
}

{
  "name": "@theholocron/jest-config",
  "version": "7.0.0",
  "description": "DEPRECATED: Use @theholocron/vitest-config instead.",
  "deprecated": "This package is no longer maintained. Migrate to @theholocron/vitest-config.",
  "homepage": "https://github.com/theholocron/configs/tree/main/packages/jest-config#readme",
  "bugs": "https://github.com/theholocron/configs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theholocron/configs.git"
  },
  "license": "GPL-3.0",
  "author": "Newton Koumantzelis",
  "keywords": [
    "jest",
    "testing",
    "deprecated",
    "config",
    "theholocron"
  ],
  "type": "module",
  "main": "dist/jest-preset.js",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@theholocron/tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/jest-preset.d.ts",
      "import": "./dist/jest-preset.js",
      "default": "./dist/jest-preset.js"
    },
    "./jest-preset": {
      "types": "./dist/jest-preset.d.ts",
      "import": "./dist/jest-preset.js",
      "default": "./dist/jest-preset.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "jest-preset.js"
  ],
  "peerDependencies": {
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "cypress": "^14",
    "jest": "^29",
    "jsdom": "^26"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "releases": "https://github.com/theholocron/configs/releases",
  "wiki": "https://github.com/theholocron/configs/wiki"
}

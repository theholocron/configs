{
  "name": "@theholocron/vitest-config",
  "version": "7.1.0",
  "description": "Vitest configuration presets for libraries, React apps, and Storybook within the Galaxy.",
  "homepage": "https://github.com/theholocron/configs/tree/main/packages/vitest-config#readme",
  "bugs": "https://github.com/theholocron/configs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theholocron/configs.git"
  },
  "license": "GPL-3.0",
  "author": "Newton Koumantzelis",
  "keywords": [
    "vitest",
    "testing",
    "coverage",
    "typescript",
    "config",
    "theholocron"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@theholocron/tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/presets/node.d.ts",
      "import": "./dist/presets/node.js",
      "default": "./dist/presets/node.js"
    },
    "./react": {
      "types": "./dist/presets/react.d.ts",
      "import": "./dist/presets/react.js",
      "default": "./dist/presets/react.js"
    },
    "./storybook": {
      "types": "./dist/presets/storybook.d.ts",
      "import": "./dist/presets/storybook.js",
      "default": "./dist/presets/storybook.js"
    },
    "./bundles/library": {
      "types": "./dist/bundles/library.d.ts",
      "import": "./dist/bundles/library.js",
      "default": "./dist/bundles/library.js"
    },
    "./bundles/react-app": {
      "types": "./dist/bundles/react-app.d.ts",
      "import": "./dist/bundles/react-app.js",
      "default": "./dist/bundles/react-app.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "peerDependencies": {
    "vitest": "^4",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@vitest/browser": "^4",
    "@vitest/coverage-v8": "^4",
    "@storybook/addon-vitest": "^9",
    "jsdom": "^26",
    "playwright": "^1"
  },
  "peerDependenciesMeta": {
    "@testing-library/react": {
      "optional": true
    },
    "@testing-library/user-event": {
      "optional": true
    },
    "@vitest/browser": {
      "optional": true
    },
    "@vitest/coverage-v8": {
      "optional": true
    },
    "@storybook/addon-vitest": {
      "optional": true
    },
    "jsdom": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "releases": "https://github.com/theholocron/configs/releases",
  "wiki": "https://github.com/theholocron/configs/wiki"
}

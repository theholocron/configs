{
  "name": "@theholocron/lint-staged-config",
  "version": "7.4.1",
  "description": "A Lint Staged configuration for linting code that has been staged in Git within the Galaxy.",
  "homepage": "https://github.com/theholocron/configs/tree/main/packages/lint-staged-config#readme",
  "bugs": "https://github.com/theholocron/configs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theholocron/configs.git"
  },
  "license": "GPL-3.0",
  "author": "Newton Koumantzelis",
  "keywords": [
    "lint-staged",
    "husky",
    "git-hooks",
    "pre-commit",
    "config",
    "theholocron"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsdown",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@theholocron/tsconfig": "workspace:*",
    "husky": "^9.1.7",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@theholocron/vitest-config": "workspace:*",
    "@vitest/coverage-v8": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "peerDependencies": {
    "husky": "^9",
    "lint-staged": "^16",
    "sort-package-json": "^4"
  },
  "peerDependenciesMeta": {
    "sort-package-json": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "releases": "https://github.com/theholocron/configs/releases",
  "wiki": "https://github.com/theholocron/configs/wiki"
}

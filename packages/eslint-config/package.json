{
  "name": "@theholocron/eslint-config",
  "version": "4.1.0",
  "description": "A ESLint configuration for writing well-formed Javascript within the Galaxy.",
  "homepage": "https://github.com/theholocron/configs/tree/main/packages/eslint-config#readme",
  "bugs": "https://github.com/theholocron/configs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theholocron/configs.git"
  },
  "license": "GPL-3.0",
  "author": "Newton Koumantzelis",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "typescript",
    "react",
    "nextjs",
    "vitest",
    "storybook"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.js",
      "default": "./index.js"
    },
    "./base": {
      "import": "./configs/base.js",
      "default": "./configs/base.js"
    },
    "./typescript": {
      "import": "./configs/typescript.js",
      "default": "./configs/typescript.js"
    },
    "./react": {
      "import": "./configs/react.js",
      "default": "./configs/react.js"
    },
    "./next": {
      "import": "./configs/next.js",
      "default": "./configs/next.js"
    },
    "./node": {
      "import": "./configs/node.js",
      "default": "./configs/node.js"
    },
    "./vitest": {
      "import": "./configs/vitest.js",
      "default": "./configs/vitest.js"
    },
    "./storybook": {
      "import": "./configs/storybook.js",
      "default": "./configs/storybook.js"
    },
    "./cypress": {
      "import": "./configs/cypress.js",
      "default": "./configs/cypress.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "configs/",
    "bundles/"
  ],
  "peerDependencies": {
    "@eslint/js": "^10",
    "@next/eslint-plugin-next": "^16",
    "@vitest/eslint-plugin": "^1",
    "eslint": "^10",
    "eslint-plugin-cypress": "^6",
    "eslint-plugin-n": "^18",
    "eslint-plugin-react": "^7",
    "eslint-plugin-storybook": "^10",
    "globals": "^16",
    "typescript-eslint": "^8"
  },
  "peerDependenciesMeta": {
    "@next/eslint-plugin-next": {
      "optional": true
    },
    "@vitest/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-cypress": {
      "optional": true
    },
    "eslint-plugin-n": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-storybook": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "releases": "https://github.com/theholocron/configs/releases",
  "wiki": "https://github.com/theholocron/configs/wiki"
}

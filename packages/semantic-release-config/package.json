{
  "name": "@theholocron/semantic-release-config",
  "version": "7.1.0",
  "description": "A semantic-release configuration for automated versioning and publishing.",
  "homepage": "https://github.com/theholocron/configs/tree/main/packages/semantic-release-config#readme",
  "bugs": "https://github.com/theholocron/configs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theholocron/configs.git"
  },
  "license": "GPL-3.0",
  "author": "Newton Koumantzelis",
  "keywords": [
    "semantic-release",
    "release",
    "versioning",
    "changelog",
    "config",
    "theholocron"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@theholocron/tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@theholocron/vitest-config": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "peerDependencies": {
    "@semantic-release/changelog": "^6",
    "@semantic-release/commit-analyzer": "^13",
    "@semantic-release/exec": "^7",
    "@semantic-release/git": "^10",
    "@semantic-release/github": "^11 || ^12",
    "@semantic-release/release-notes-generator": "^14",
    "conventional-changelog-conventionalcommits": "^10",
    "semantic-release": "^24 || ^25"
  },
  "peerDependenciesMeta": {
    "@semantic-release/exec": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "releases": "https://github.com/theholocron/configs/releases",
  "wiki": "https://github.com/theholocron/configs/wiki"
}
